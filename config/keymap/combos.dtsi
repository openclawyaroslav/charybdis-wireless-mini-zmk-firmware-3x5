/ {
    combos {
        compatible = "zmk,combos";

        CapsWord {
            bindings = <&caps_word>;
            key-positions = <14 15>;
            layers = <0>;
        };

        combo_BASE_or_EXTRAS {
            bindings = <&td_bore>;
            key-positions = <32 33>;
        };
        
        combo_left_click {
            bindings = <&mkp LCLK>;
            key-positions = <20 21>;
        };
        
        combo_middle_click {
            bindings = <&mkp MCLK>;
            key-positions = <21 22>;
        };

        combo_right_click {
            bindings = <&mkp RCLK>;
            key-positions = <22 23>;
        };
    };
};